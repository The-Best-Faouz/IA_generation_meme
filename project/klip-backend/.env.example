# ==========================================
# K L I P   B A C K E N D   -   E N V
# ==========================================
# Copie ce fichier en .env et remplace les valeurs
# NE COMMITE JAMAIS le fichier .env dans git
# ==========================================

PORT=3000
NODE_ENV=development

# Base de données MongoDB (Atlas ou local)
MONGODB_URI=mongodb://localhost:27017/klip

# Authentification JWT (génère des secrets uniques avec: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# URL du backend sur Render (pour keep-alive, optionnel)
RENDER_URL=

# URL frontend (pour CORS - séparer par des virgules si plusieurs)
FRONTEND_URL=http://localhost:8081

# APIs IA - Obtenir les clés sur chaque plateforme
GEMINI_API_KEY=CHANGE_ME
OPENAI_API_KEY=CHANGE_ME
HUGGINGFACE_API_KEY=CHANGE_ME
GROQ_API_KEY=CHANGE_ME
REPLICATE_API_TOKEN=CHANGE_ME

# Telegram Bot Token (optionnel)
TELEGRAM_BOT_TOKEN=CHANGE_ME

# Cloudinary (optionnel, pour stockage d'images)
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME
